# ============================================================
# Interviewer Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# NVIDIA NIM API  (required — powers all AI features)
# Get a free key at: https://build.nvidia.com
# Sign up → API Catalog → any model → "Get API Key"
# ----------------------------------------------------------
NVIDIA_API_KEY=nvapi-your-key-here

# Default model (works out of the box, no changes needed)
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ----------------------------------------------------------
# GitHub Token  (optional — needed for GitHub profile analysis)
# Get one at: https://github.com/settings/tokens
# Create a "Fine-grained token" with public repo read access
# Without this, only resume-based interviews will work
# ----------------------------------------------------------
GITHUB_TOKEN=ghp_your_github_token_here

# ----------------------------------------------------------
# Owner Dashboard Password  (required)
# Choose a strong password — this protects the owner portal
# where you can view scores, reports, and candidate comparisons
# ----------------------------------------------------------
OWNER_PASSWORD=choose-a-strong-password-here

# ----------------------------------------------------------
# Data Encryption Key  (required)
# Protects candidate data at rest (sessions, profiles, reports).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Store this key securely — if lost, encrypted data is unrecoverable.
# Do NOT store this key inside the data/ directory.
# ----------------------------------------------------------
DATA_ENCRYPTION_KEY=generate-a-key-see-above
